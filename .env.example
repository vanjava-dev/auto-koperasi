# ─────────────────────────────────────────────────────────
#  KOPERASI-AI — Environment Variables Template
#  Salin file ini menjadi `.env.local` dan isi dengan nilai asli.
#  JANGAN PERNAH commit file `.env.local` ke Git!
# ─────────────────────────────────────────────────────────

# === DATABASE (PostgreSQL via Prisma) ===
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/koperasi_ai_db?schema=public"

# === AUTH (NextAuth.js / Auth.js) ===
NEXTAUTH_SECRET="ganti-dengan-secret-acak-minimal-32-karakter"
NEXTAUTH_URL="http://localhost:3000"

# === XENDIT PAYMENT GATEWAY ===
XENDIT_SECRET_KEY="xnd_development_XXXXXXXXXXXXXXXX"
XENDIT_WEBHOOK_TOKEN="token-validasi-webhook-xendit-anda"
XENDIT_CALLBACK_URL="https://yourdomain.com/api/webhooks/xendit"

# === AI / GEMINI (Google AI) ===
GEMINI_API_KEY="AIzaSy-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
GOOGLE_AI_API_KEY="AIzaSy-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX" # Fallback/Alias
# Model untuk OCR KTP
GEMINI_VISION_MODEL="gemini-1.5-flash"
# Model untuk AI Chat Agent
GEMINI_CHAT_MODEL="gemini-1.5-pro"

# === BACKGROUND JOBS (Cron Security) ===
CRON_SECRET="ganti-dengan-secret-acak-untuk-mengamankan-panggilan-cron"

# === APLIKASI ===
NEXT_PUBLIC_APP_NAME="Koperasi-AI"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Nama resmi koperasi (ditampilkan di UI)
NEXT_PUBLIC_KOPERASI_NAME="KSP Harapan Artha Nusantara"

# === NOTIFIKASI (Opsional — WhatsApp/Email) ===
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
